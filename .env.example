# Copie este arquivo para .env e preencha os valores reais.
# NUNCA suba o arquivo .env para o repositório.

# Gere uma chave segura com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=sua-chave-secreta-aqui

# Em produção, mantenha como False
DEBUG=False

# Coloque o domínio do seu deploy (ex: meusite.onrender.com)
ALLOWED_HOSTS=meusite.onrender.com

# URL completa do site para CSRF (ex: https://meusite.onrender.com)
CSRF_TRUSTED_ORIGINS=https://meusite.onrender.com
